{
  "name": "@restorecommerce/identity-srv",
  "version": "1.5.0",
  "description": "Restorecommerce identity service",
  "main": "lib/start.js",
  "author": "n-fuse GmbH",
  "repository": {
    "type": "git",
    "url": "https://github.com/restorecommerce/identity-srv.git"
  },
  "license": "MIT",
  "keywords": [
    "restore",
    "commerce",
    "microservice",
    "identity",
    "srv"
  ],
  "dependencies": {
    "@restorecommerce/acs-client": "^3.1.2",
    "@restorecommerce/chassis-srv": "^1.7.3",
    "@restorecommerce/grpc-client": "^2.2.12",
    "@restorecommerce/kafka-client": "^1.3.2",
    "@restorecommerce/logger": "^1.3.7",
    "@restorecommerce/rc-grpc-clients": "^5.1.61",
    "@restorecommerce/resource-base-interface": "^1.9.3",
    "@restorecommerce/scs-jobs": "^0.2.2",
    "@restorecommerce/service-config": "^1.1.6",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-de": "^3.0.2",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "@zxcvbn-ts/matcher-pwned": "^3.0.4",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.59.0",
    "cross-env": "^10.1.0",
    "jose": "5.9.6",
    "lodash-es": "^4.17.21",
    "nice-grpc-server-reflection": "^3.0.2",
    "node-fetch": "^3.3.2",
    "oauth": "^0.10.2",
    "otplib": "^12.0.1",
    "redis": "^4.6.14",
    "source-map-support": "^0.5.21",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@alenon/grpc-mock-server": "^3.2.3",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@restorecommerce/dev": "^0.1.2",
    "@restorecommerce/protos": "^6.11.10",
    "@semantic-release-plus/docker": "^3.1.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/lodash": "^4.17.20",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "22.13.14",
    "@types/oauth": "^0.9.6",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild": "^0.25.10",
    "eslint": "^9.36.0",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.1",
    "should": "^13.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "start": "node lib/start.cjs",
    "dev": "cross-env NODE_ENV=development node --watch lib/start.cjs",
    "test": "npm run lint && vitest run",
    "lint": "eslint src",
    "build:es": "esbuild ./src/start.ts --bundle --platform=node --outfile=lib/start.cjs --minify --tree-shaking=true --sourcemap=inline",
    "build:jobs": "find ./src/jobs -maxdepth 1 -type f -exec sh -c 'esbuild {} --bundle --platform=node --outfile=lib/jobs/$(basename {} .ts).cjs --minify --tree-shaking=true --sourcemap=inline' \\;",
    "build:clean": "rimraf lib",
    "build": "npm-run-all lint build:clean build:es build:jobs",
    "prepare": "node -e \"try { require('husky').install() } catch (e) {}\""
  },
  "engines": {
    "node": ">= 22.0.0"
  },
  "type": "module",
  "release": {
    "branches": [
      "master"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/github",
      [
        "@semantic-release-plus/docker",
        {
          "name": "docker.io/restorecommerce/identity-srv",
          "skipLogin": true
        }
      ],
      [
        "@semantic-release-plus/docker",
        {
          "name": "ghcr.io/restorecommerce/identity-srv",
          "skipLogin": true
        }
      ]
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
